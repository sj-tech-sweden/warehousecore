{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LED Command Schema",
  "description": "Schema for LED highlight commands sent via MQTT to ESP32 controllers",
  "type": "object",
  "required": ["op", "warehouse_id"],
  "properties": {
    "op": {
      "type": "string",
      "enum": ["highlight", "clear", "identify"],
      "description": "Operation to perform: highlight (show bins), clear (turn off all), identify (blink all for testing)"
    },
    "warehouse_id": {
      "type": "string",
      "description": "Warehouse identifier (e.g., 'weidelbach')",
      "minLength": 1
    },
    "shelves": {
      "type": "array",
      "description": "Array of shelves with bins to highlight",
      "items": {
        "type": "object",
        "required": ["shelf_id", "bins"],
        "properties": {
          "shelf_id": {
            "type": "string",
            "description": "Shelf identifier (e.g., 'A', 'B', 'Rack-01')"
          },
          "bins": {
            "type": "array",
            "description": "Bins within this shelf to highlight",
            "items": {
              "type": "object",
              "required": ["bin_id", "pixels"],
              "properties": {
                "bin_id": {
                  "type": "string",
                  "description": "Bin identifier (e.g., 'A-01', 'A-02')"
                },
                "pixels": {
                  "type": "array",
                  "description": "Array of LED pixel indices for this bin (supports multiple LEDs per bin)",
                  "items": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "minItems": 1
                },
                "color": {
                  "type": "string",
                  "description": "Hex color code (e.g., '#FF0000' for red)",
                  "pattern": "^#[0-9A-Fa-f]{6}$",
                  "default": "#FF2A2A"
                },
                "pattern": {
                  "type": "string",
                  "enum": ["solid", "blink", "breathe"],
                  "description": "LED animation pattern",
                  "default": "breathe"
                },
                "intensity": {
                  "type": "integer",
                  "description": "Brightness level (0-255)",
                  "minimum": 0,
                  "maximum": 255,
                  "default": 180
                }
              }
            }
          }
        }
      }
    }
  }
}
