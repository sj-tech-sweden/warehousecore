# StorageCore Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8081
HOST=0.0.0.0

# Database (Shared with RentalCore)
DB_HOST=tsunami-events.de
DB_USER=tsweb
DB_PASS=your_password_here
DB_NAME=RentalCore
DB_PORT=3306

# Application
APP_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_here

# LED MQTT Configuration
LED_MQTT_HOST=broker.example.com
LED_MQTT_PORT=8883
LED_MQTT_TLS=true
LED_MQTT_USER=your_mqtt_user
LED_MQTT_PASS=your_mqtt_password
LED_TOPIC_PREFIX=weidelbach
WAREHOUSE_ID=weidelbach
