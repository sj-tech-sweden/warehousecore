# StorageCore Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8081
HOST=0.0.0.0

# Database (Shared with RentalCore - PostgreSQL)
DB_HOST=localhost
DB_USER=warehouse_user
DB_PASSWORD=your_password_here
DB_NAME=rentalcore
DB_PORT=5432
DB_SSLMODE=disable

# Application
APP_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_here

# Auto-Admin assignment
# User whose name/username/email contains this string will be auto-granted admin role on startup
ADMIN_NAME_MATCH=Admin

# LED MQTT Configuration
#
# Option 1: Self-Hosted Mosquitto (docker-compose) - RECOMMENDED
# Use this when running Mosquitto in the same docker-compose stack
# Default credentials are pre-configured - just copy this .env.example to .env and run docker-compose up -d
LED_MQTT_HOST=mosquitto
LED_MQTT_PORT=1883
LED_MQTT_TLS=false
LED_MQTT_USER=leduser
LED_MQTT_PASS=ledpassword123
#
# Option 2: Cloud MQTT Broker (EMQX, HiveMQ, etc.)
# Uncomment and use these settings for cloud-hosted MQTT:
# LED_MQTT_HOST=broker.example.com
# LED_MQTT_PORT=8883
# LED_MQTT_TLS=true
# LED_MQTT_USER=your_cloud_mqtt_user
# LED_MQTT_PASS=your_cloud_mqtt_password
#
# Common settings for both options:
LED_TOPIC_PREFIX=warehousecore
WAREHOUSE_ID=MAIN  # Main warehouse zone code from storage_zones table (e.g., "MAIN" for primary warehouse)

# Cross-links domains (optional, used for navbar links)
# Provide bare domains (no protocol), e.g. rent.server-nt.de
RENTALCORE_DOMAIN=
WAREHOUSECORE_DOMAIN=

# Eventory integration (optional – can also be configured via the admin UI)
# EVENTORY_API_URL=https://api.eventory.se
# EVENTORY_API_KEY=your_eventory_api_key_here
