{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZoneType",
  "type": "object",
  "properties": {
    "key": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "default_led_pattern": { "type": "string", "enum": ["solid", "breathe", "blink"] },
    "default_led_color": { "type": "string", "pattern": "^#(?:[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
    "default_intensity": { "type": "integer", "minimum": 0, "maximum": 255 }
  },
  "required": ["key", "label"],
  "additionalProperties": false
}

